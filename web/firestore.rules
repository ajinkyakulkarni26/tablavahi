rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function validKind(kind) {
      return kind in [
        "taal",
        "kayda",
        "peshkar",
        "prakaar",
        "rela",
        "tukda",
        "chakradar",
        "other"
      ];
    }

    function hasCompositionShape(data) {
      return data.keys().hasOnly([
        "id",
        "taalId",
        "kind",
        "ownerUid",
        "ownerDisplayName",
        "title",
        "titleDevanagari",
        "lines",
        "notes",
        "guruNote",
        "createdAt",
        "updatedAt"
      ]) &&
      data.id is string &&
      data.taalId is string &&
      validKind(data.kind) &&
      data.ownerUid is string &&
      data.title is string &&
      data.lines is list &&
      data.createdAt is string &&
      data.updatedAt is string;
    }

    // Shared library: everyone can read, only owner can create/update/delete own docs.
    match /compositions/{compositionId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        hasCompositionShape(request.resource.data) &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.ownerUid == request.auth.uid &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        hasCompositionShape(request.resource.data);
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
